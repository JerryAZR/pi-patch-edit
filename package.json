{
  "name": "pi-patch-edit",
  "version": "0.1.0",
  "description": "A git-diff/patch-inspired edit tool for the pi coding agent. Shadows the built-in edit with a unified-diff interface.",
  "keywords": ["pi-package"],
  "license": "MIT",
  "author": "",
  "repository": "github:JerryAZR/pi-patch-edit",
  "type": "module",
  "private": true,
  "files": ["src", "README.md", "LICENSE"],
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "test:watch": "node --import tsx --test --watch test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "diff": "^8.0.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typebox": "*",
    "typescript": "^5.6.0"
  },
  "pi": {
    "extensions": ["./src/index.ts"]
  }
}
